  "scripts": {
    "start": "craco start",
    "build": "GENERATE_SOURCEMAP=false NODE_OPTIONS='--openssl-legacy-provider' craco --max-old-space-size=4096 build",
    "build:win": "set \"GENERATE_SOURCEMAP=false\" && craco --max-old-space-size=4096 build",
    "build:unix": "GENERATE_SOURCEMAP=false NODE_OPTIONS='--openssl-legacy-provider' craco --max-old-space-size=4096 build",
    "test": "craco test",
    "eject": "craco eject",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "lint:check": "eslint src --ext .js,.jsx --max-warnings 0",
    "lint:staged": "eslint --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css,md}\"",
    "lint:charts": "eslint src/container/charts --ext .js,.jsx --fix",
    "lint:components": "eslint src/components --ext .js,.jsx --fix",
    "lint:redux": "eslint src/redux --ext .js,.jsx --fix",
    "pre-commit": "npm run lint:check && npm run format:check",
    "dev:clean": "npm run lint:fix && npm run format"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "browser": {
    "[module-name]": false
